{
  "version": 2,
  "builds": [
    {
      "src": "server/src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/src/server.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "client/dist/assets/$1"
    },
    {
      "src": "/((?!api/).*\\..*)",
      "dest": "client/dist/$1"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "client/dist/index.html"
    }
  ]
}
